# ========== Notion 连接（也可在网页首次配置 / 后台填写）==========

# 访问令牌（ntn_ 开头）
# 获取：https://app.notion.com/developers → 连接 → 新连接 → 复制访问令牌
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 数据库 ID（网址 /p/ 后约 32 位字符，不要用 ?v= 后面的）
# 例：https://app.notion.com/p/xxxxxxxxxxxxxxxxxxxx?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：Data Source ID（新版 API）；留空会自动探测
# NOTION_DATA_SOURCE_ID=

# 会话加密密钥（≥32 字符，生产 / Docker 务必修改）
SESSION_SECRET=please-change-to-a-long-random-string-32+

# Cookie 是否仅 HTTPS（默认 0，方便 IP:端口 HTTP 访问）
# 有 HTTPS 域名时请改为 1
COOKIE_SECURE=0

# Docker Compose 映射端口（可选）
# PORT=3000
