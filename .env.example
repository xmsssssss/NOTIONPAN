# ========== Docker / 生产（可选）==========
# 复制为 .env 后按需修改。Notion 连接默认不在此填写，登录后按网页引导配置。

# 会话加密密钥（≥32 字符）
# 生产 / Docker 必填；未配置时生产环境会拒绝签发会话
SESSION_SECRET=please-change-to-a-long-random-string-32+

# Cookie 是否仅 HTTPS（默认 0，方便 IP:端口 HTTP 访问）
# 有 HTTPS 域名时请改为 1
COOKIE_SECURE=0

# 对外访问地址（可选）。Docker / 反代时分享链接建议填写，如 https://pan.example.com
# 不填则用请求 Host / X-Forwarded-*；勿依赖 0.0.0.0
# PUBLIC_URL=https://pan.example.com

# WebDAV：挂载地址 http(s)://你的域名/webdav/
# 账号密码 = 站点管理员账号密码（HTTP Basic）
# 也可在后台「WebDAV」页配置：
# WEBDAV_PROXY_DOWNLOAD=0   # 0/空=302 到 Notion；1=本机反代
# PUBLIC_URL=https://pan.example.com

# Docker Compose 映射端口（可选）
# PORT=3000

# ========== Notion（可选，也可网页首次配置 / 后台填写）==========
# 一般不必写进 .env；需要启动时注入时再取消注释：
# NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATA_SOURCE_ID=
# Notion Webhook 校验令牌（可选；配置 Webhook 后自动写入，也可手动粘贴）
# NOTION_WEBHOOK_TOKEN=
